# Copy to .env and fill in values

# MongoDB
# Local: mongodb://127.0.0.1:27017/elite-notes
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/elite-notes
MONGO_URI=mongodb://127.0.0.1:27017/elite-notes

# JWT signing secret for admin login cookies
JWT_SECRET=change-this-to-a-long-random-string

# Cloudinary (optional — product image uploads in admin)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
